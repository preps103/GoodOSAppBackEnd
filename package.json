{
  "name": "goodapp-backend",
  "version": "1.0.0",
  "description": "GoodAppBackEnd - self-hosted backend for GoodOS",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/goodapp-worker.js",
    "jobs:run-once": "node scripts/run-job-once.js",
    "jobs:health": "node -e \"require('./src/services/job.service').getJobsSnapshot().then(x=>console.log(JSON.stringify(x.counts,null,2))).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "keywords": [
    "goodos",
    "backend",
    "self-hosted"
  ],
  "author": "GoodOS",
  "license": "PRIVATE",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "9.0.3",
    "openid-client": "6.8.4",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
