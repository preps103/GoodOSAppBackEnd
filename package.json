{
  "name": "goodbase",
  "version": "1.0.0",
  "description": "Goodbase — the production backend platform for GoodOS applications",
  "private": true,
  "main": "src/server.js",
  "bin": {
    "goodbase": "bin/goodbase.js",
    "goodos": "bin/goodbase.js"
  },
  "engines": {
    "node": ">=22.22.3 <23",
    "npm": ">=10.9.8 <11"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker": "node src/workers/goodapp-worker-v3.js",
    "check": "npm run check:syntax && npm run check:openapi && npm test",
    "check:syntax": "find src scripts test bin -type f -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "check:openapi": "node scripts/validate-openapi.js",
    "test": "node --test test/*.test.js",
    "enterprise:readiness": "node scripts/enterprise-readiness.js",
    "jobs:run-once": "node scripts/run-job-once.js",
    "jobs:health": "node -e \"require('./src/services/job.service').getJobsSnapshot().then(x=>console.log(JSON.stringify(x.counts,null,2))).catch(e=>{console.error(e);process.exit(1)})\"",
    "assurance:run": "node scripts/goodbase-assurance.js",
    "security:gate": "node scripts/goodbase-security-gate.js",
    "load:approved": "node scripts/goodbase-load.js",
    "chaos:approved": "node scripts/goodbase-chaos.js",
    "ci:evidence": "node scripts/goodbase-record-ci.js",
    "certify:production": "node scripts/goodbase-certify.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/preps103/Goodbase.git"
  },
  "keywords": [
    "goodbase",
    "backend-as-a-service",
    "self-hosted",
    "enterprise"
  ],
  "author": "GoodOS",
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "8.6.0",
    "graphql": "16.11.0",
    "helmet": "8.3.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nodemailer": "9.0.3",
    "openid-client": "6.8.4",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
