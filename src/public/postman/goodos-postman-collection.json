{
  "info": {
    "name": "GoodOS Public API",
    "_postman_id": "goodos-public-api",
    "description": "GoodAppBackEnd public API collection. Set GOODOS_API_KEY in collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://backend.goodos.app/api/v1"
    },
    {
      "key": "GOODOS_API_KEY",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Apps",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/apps"
      }
    },
    {
      "name": "Storage Buckets",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/storage/buckets"
      }
    },
    {
      "name": "Storage Files",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/storage/files"
      }
    },
    {
      "name": "Call Function - Health Check",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"postman\",\n  \"message\": \"Testing GoodOS callable function\"\n}"
        },
        "url": "{{base_url}}/functions/health-check"
      }
    },
    {
      "name": "Database API - Tables",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/db/tables"
      }
    },
    {
      "name": "Database API - Apps Rows",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/db/apps/rows"
      }
    },
    {
      "name": "Database API - Create Demo Item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Created from Postman\",\n  \"status\": \"active\"\n}"
        },
        "url": "{{base_url}}/db/demo-items/rows"
      }
    },
    {
      "name": "Storage V2 - Public Object",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://backend.goodos.app/storage/public/storage-v2-public/v2-public-health.txt"
      }
    },
    {
      "name": "Edge Functions V2 - Health Check",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"source\": \"postman\",\n  \"message\": \"Edge Functions V2\",\n  \"_goodosRuntime\": \"edge-functions-v2\"\n}"
        },
        "url": "{{base_url}}/functions/health-check"
      }
    },
    {
      "name": "Realtime V2 - Channels",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/realtime/channels"
      }
    },
    {
      "name": "Realtime V2 - Publish",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"channel\": \"system\",\n  \"eventType\": \"postman.message\",\n  \"message\": \"Hello Realtime V2\",\n  \"payload\": { \"ok\": true }\n}"
        },
        "url": "{{base_url}}/realtime/events"
      }
    },
    {
      "name": "Auth V2 - Session",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://backend.goodos.app/api/auth/session"
      }
    },
    {
      "name": "Auth V2 - Password Reset Request",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\"\n}"
        },
        "url": "https://backend.goodos.app/api/auth/password-reset/request"
      }
    },
    {
      "name": "Usage V2 - Billing Plans",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/billing/plans"
      }
    },
    {
      "name": "Usage V2 - Usage Snapshot",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/usage"
      }
    },
    {
      "name": "Notifications V2 - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "url": "{{base_url}}/notifications"
      }
    },
    {
      "name": "Notifications V2 - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-GoodOS-API-Key",
            "value": "{{GOODOS_API_KEY}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"System notice\",\n  \"message\": \"Hello from Notifications V2\",\n  \"severity\": \"info\",\n  \"category\": \"system\",\n  \"channel\": \"in_app\"\n}"
        },
        "url": "{{base_url}}/notifications"
      }
    },
    {
      "name": "Jobs V2 - Page Data",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://backend.goodos.app/api/admin/jobs-page-data"
      }
    },
    {
      "name": "Jobs V2 - Run Due Jobs",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"limit\": 10\n}"
        },
        "url": "https://backend.goodos.app/api/admin/jobs/run-due-safe"
      }
    }
  ]
}
