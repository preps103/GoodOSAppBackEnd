# Goodbase Phase 1 data-plane environment.
# Copy to /etc/goodos/data-platform.env with mode 0600.
# Internal goodos_* role and schema names remain for backward compatibility.
# Never commit real values.

PGRST_DB_URI=postgres://goodos_postgrest_authenticator:replace-me@127.0.0.1:5432/goodos_backend
PGRST_DB_PASSWORD=replace-me
GOODOS_JWT_SECRET=replace-me
PGRST_DB_POOL=20
PGRST_DB_POOL_ACQUISITION_TIMEOUT=10
PGRST_DB_MAX_ROWS=1000
PGRST_LOG_LEVEL=info

GOODBASE_DB_NAME=goodos_backend
GOODBASE_TRANSACTION_POOL_PASSWORD=replace-me
GOODBASE_SESSION_POOL_PASSWORD=replace-me
GOODBASE_TRANSACTION_MAX_CLIENTS=200
GOODBASE_TRANSACTION_POOL_SIZE=20
GOODBASE_TRANSACTION_RESERVE_SIZE=5
GOODBASE_SESSION_MAX_CLIENTS=100
GOODBASE_SESSION_POOL_SIZE=10
GOODBASE_SESSION_RESERVE_SIZE=2

# Reserved for Phase 2 PostgreSQL-change Realtime.
REALTIME_DB_NAME=goodos_backend
REALTIME_DB_USER=goodbase_realtime
REALTIME_DB_PASSWORD=replace-me
REALTIME_DB_ENC_KEY=replace-me-16ch
REALTIME_API_JWT_SECRET=replace-me
REALTIME_SECRET_KEY_BASE=replace-me
REALTIME_MAX_CONNECTIONS=10000
REALTIME_NUM_ACCEPTORS=100
REALTIME_JWT_CLAIM_VALIDATORS={"iss":"https://base.goodos.app"}
