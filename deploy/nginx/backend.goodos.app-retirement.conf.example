# Deprecated Goodbase hostname. Keep only through 2027-01-21 so existing clients
# receive a method-preserving redirect while they migrate to base.goodos.app.
server {
    listen 80;
    listen [::]:80;
    server_name backend.goodos.app;
    return 308 https://base.goodos.app$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name backend.goodos.app;

    ssl_certificate /etc/letsencrypt/live/backend.goodos.app/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/backend.goodos.app/privkey.pem;

    add_header Deprecation "true" always;
    add_header Sunset "Wed, 21 Jan 2027 00:00:00 GMT" always;
    add_header Link '<https://base.goodos.app>; rel="successor-version"' always;
    return 308 https://base.goodos.app$request_uri;
}
