    "/realtime/ws": {
      "get": {
        "summary": "Realtime V2 WebSocket endpoint",
        "description": "Connect to wss://base.goodos.app/api/v1/realtime/ws?api_key=YOUR_KEY&channel=system with subscribe:realtime scope. Publish messages with publish:realtime scope.",
        "x-goodos-scope": "subscribe:realtime",
        "responses": {
