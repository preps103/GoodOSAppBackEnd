{
  "openapi": "3.1.0",
  "info": {
    "title": "GoodOS Public API",
    "version": "1.0.0",
    "description": "GoodAppBackEnd public API for GoodOS apps. All public endpoints require an API key using X-GoodOS-API-Key or Authorization: Bearer."
  },
  "servers": [
    {
      "url": "https://base.goodos.app/api/v1",
      "description": "GoodOS Production Public API"
    }
  ],
  "security": [
    {
      "GoodOSApiKey": []
    },
    {
      "GoodOSBearer": []
    }
  ],
  "components": {
    "securitySchemes": {
      "GoodOSApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-GoodOS-API-Key"
      },
      "GoodOSBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "ApiKeyContext": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "allowedAppIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "const": false
          },
          "message": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Public API health check",
        "description": "Requires scope: read:health",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:health",
        "responses": {
          "200": {
            "description": "Health response",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "service": "GoodAppBackEnd Public API",
                  "status": "ok",
                  "apiKey": {
                    "id": "key_xxx",
                    "name": "Function Execute Key",
                    "type": "scoped",
                    "scopes": [
                      "read:health"
                    ]
                  },
                  "time": "2026-06-26T00:00:00.000Z"
                }
              }
            }
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          }
        }
      }
    },
    "/apps": {
      "get": {
        "summary": "List apps allowed for the API key",
        "description": "Requires scope: read:apps. App results are filtered by allowed_app_ids on the API key.",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:apps",
        "responses": {
          "200": {
            "description": "Allowed apps",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "apps": [
                      {
                        "id": "goodfleet",
                        "name": "GoodFleet",
                        "domain": "fleet.goodos.app",
                        "status": "active",
                        "memberCount": 1
                      }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          }
        }
      }
    },
    "/storage/buckets": {
      "get": {
        "summary": "List storage buckets",
        "description": "Requires scope: read:storage. Returns Storage V2 bucket metadata including provider/CDN fields when available.",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:storage",
        "responses": {
          "200": {
            "description": "Storage buckets"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          }
        }
      }
    },
    "/storage/files": {
      "get": {
        "summary": "List storage files",
        "description": "Requires scope: read:storage. Returns Storage V2 file/object metadata including object keys, checksums, versions, and public/CDN URLs when available.",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:storage",
        "parameters": [
          {
            "name": "bucket",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Storage files"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          }
        }
      }
    },
    "/functions/{slug}": {
      "get": {
        "summary": "Call an HTTP Edge Function using GET",
        "description": "Requires scope: execute:functions. Executes through the GoodOS Edge Functions V2 controlled runtime when V2 metadata is enabled.",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "execute:functions",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "health-check"
          }
        ],
        "responses": {
          "200": {
            "description": "Function execution result"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          },
          "404": {
            "description": "Function not found"
          }
        },
        "x-goodos-runtime": "edge-functions-v2"
      },
      "post": {
        "summary": "Call an HTTP Edge Function using POST",
        "description": "Requires scope: execute:functions. Executes through the GoodOS Edge Functions V2 controlled runtime when V2 metadata is enabled.",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "execute:functions",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "health-check"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "example": {
                "source": "developer-docs",
                "message": "Testing GoodOS callable function"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Function execution result"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          },
          "404": {
            "description": "Function not found"
          }
        },
        "x-goodos-runtime": "edge-functions-v2"
      }
    },
    "/db/tables": {
      "get": {
        "summary": "List published Database API tables",
        "description": "Requires scope: read:db",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:db",
        "responses": {
          "200": {
            "description": "Published tables"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope"
          }
        }
      }
    },
    "/db/{tableSlug}/rows": {
      "get": {
        "summary": "List rows from a published table",
        "description": "Requires scope: read:db",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:db",
        "parameters": [
          {
            "name": "tableSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "apps"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Table rows"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope or table disabled"
          },
          "404": {
            "description": "Published table not found"
          }
        }
      },
      "post": {
        "summary": "Create a row in a write-enabled published table",
        "description": "Requires scope: write:db and table insert permission",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "write:db",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "title": "New demo item",
                "status": "active"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Row created"
          },
          "401": {
            "description": "API key required"
          },
          "403": {
            "description": "Missing required scope or table disabled"
          }
        }
      }
    },
    "/db/{tableSlug}/rows/{id}": {
      "get": {
        "summary": "Get one row from a published table",
        "description": "Requires scope: read:db",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "read:db",
        "parameters": [
          {
            "name": "tableSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Table row"
          }
        }
      },
      "patch": {
        "summary": "Update a row in a write-enabled published table",
        "description": "Requires scope: write:db and table update permission",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "write:db",
        "parameters": [
          {
            "name": "tableSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row updated"
          }
        }
      },
      "delete": {
        "summary": "Delete or soft-delete a row in a write-enabled published table",
        "description": "Requires scope: write:db and table delete permission",
        "security": [
          {
            "GoodOSApiKey": []
          },
          {
            "GoodOSBearer": []
          }
        ],
        "x-goodos-scope": "write:db",
        "parameters": [
          {
            "name": "tableSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Row deleted"
          }
        }
      }
    },
    "/storage/public/{bucketName}/{objectKey}": {
      "get": {
        "summary": "Read a public Storage V2 object",
        "description": "Public object delivery route for buckets marked public or public_read_enabled. This route is served from the root backend domain, not /api/v1.",
        "servers": [
          {
            "url": "https://base.goodos.app"
          }
        ],
        "parameters": [
          {
            "name": "bucketName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "storage-v2-public"
          },
          {
            "name": "objectKey",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "v2-public-health.txt"
          }
        ],
        "responses": {
          "200": {
            "description": "Object file"
          },
          "403": {
            "description": "Bucket or path blocked"
          },
          "404": {
            "description": "Object not found"
          }
        }
      }
    },
    "/functions/{slug}/v2-runtime": {
      "get": {
        "summary": "Edge Functions V2 runtime metadata",
