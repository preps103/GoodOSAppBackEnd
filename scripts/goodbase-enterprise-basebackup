#!/usr/bin/env bash
set -Eeuo pipefail
umask 077

DATABASE="goodos_backend"

AGE="/usr/bin/age"
IDENTITY="/etc/goodos/backup-age.key"
RECIPIENT_FILE="/etc/goodos/backup-age-recipient.txt"

BACKUP_ROOT="/var/backups/goodos-enterprise-v1/base"

PG_VERIFYBACKUP="$(
  command -v pg_verifybackup ||
  true
)"

if [ -z "$PG_VERIFYBACKUP" ]; then
  PG_MAJOR="$(
    sudo -u postgres psql \
      -d "$DATABASE" \
      -At \
      -v ON_ERROR_STOP=1 \
      -c "
        SELECT current_setting(
          'server_version_num'
        )::int / 10000;
      "
  )"

  PG_VERIFYBACKUP="/usr/lib/postgresql/$PG_MAJOR/bin/pg_verifybackup"
fi

test -x "$AGE"
test -x "$PG_VERIFYBACKUP"
test -r "$IDENTITY"
test -r "$RECIPIENT_FILE"

TABLESPACES="$(
  sudo -u postgres psql \
    -d "$DATABASE" \
    -At \
    -v ON_ERROR_STOP=1 \
    -c "
      SELECT COUNT(*)
      FROM pg_tablespace
      WHERE spcname NOT IN (
        'pg_default',
        'pg_global'
      );
    "
)"

if [ "$TABLESPACES" != "0" ]; then
  echo "ERROR: User-defined tablespaces prevent single-stream backup."
  exit 1
fi

STAMP="$(date -u +%Y%m%dT%H%M%SZ)"
BACKUP_ID="basebackup_age_${STAMP}_$RANDOM"

FILE_NAME="postgres-cluster-${STAMP}.tar.gz.age"
FILE_PATH="$BACKUP_ROOT/$FILE_NAME"

TEMP_ENCRYPTED="$BACKUP_ROOT/.${FILE_NAME}.$$.$RANDOM.tmp"
CHECKSUM_PATH="${FILE_PATH}.sha256"
TEMP_CHECKSUM="${CHECKSUM_PATH}.$$.$RANDOM.tmp"
TEMP_PLAINTEXT="$(mktemp "$BACKUP_ROOT/.verify-XXXXXX.tar.gz")"
VERIFY_DIRECTORY="$(mktemp -d "$BACKUP_ROOT/.verify-directory-XXXXXX")"

PG_BASEBACKUP_ERROR="$(mktemp)"
AGE_ERROR="$(mktemp)"

STARTED_AT="$(date -u -Is)"
START_EPOCH="$(date +%s)"

RETENTION_UNTIL="$(
  date -u \
    -d '+30 days' \
    -Is
)"

cleanup() {
  rm -f \
    "$TEMP_ENCRYPTED" \
    "$TEMP_CHECKSUM" \
    "$TEMP_PLAINTEXT" \
    "$PG_BASEBACKUP_ERROR" \
    "$AGE_ERROR"

  rm -rf "$VERIFY_DIRECTORY"
}

trap cleanup EXIT

mkdir -p "$BACKUP_ROOT"
chmod 700 "$BACKUP_ROOT"

set +e

sudo -u postgres \
  pg_basebackup \
  --pgdata=- \
  --format=tar \
  --wal-method=fetch \
  --compress=gzip:6 \
  --manifest-checksums=SHA256 \
  --label="GoodOS Enterprise PITR ${STAMP}" \
  --max-rate=50M \
  --no-password \
  2>"$PG_BASEBACKUP_ERROR" |
"$AGE" \
  --encrypt \
  --recipients-file "$RECIPIENT_FILE" \
  --output "$TEMP_ENCRYPTED" \
  2>"$AGE_ERROR"

PIPE_RESULTS=("${PIPESTATUS[@]}")

set -e

BASEBACKUP_STATUS="${PIPE_RESULTS[0]}"
AGE_STATUS="${PIPE_RESULTS[1]}"

if [ "$BASEBACKUP_STATUS" -ne 0 ]; then
  cat "$PG_BASEBACKUP_ERROR" >&2
  echo "ERROR: pg_basebackup failed."
  exit 1
fi

if [ "$AGE_STATUS" -ne 0 ]; then
  cat "$AGE_ERROR" >&2
  echo "ERROR: Base-backup encryption failed."
  exit 1
fi

test -s "$TEMP_ENCRYPTED"

"$AGE" \
  --decrypt \
  --identity "$IDENTITY" \
  --output "$TEMP_PLAINTEXT" \
  "$TEMP_ENCRYPTED"

test -s "$TEMP_PLAINTEXT"

tar \
  -tzf "$TEMP_PLAINTEXT" \
  >/tmp/goodos-basebackup-list.txt

grep -Eq \
  '(^|/)backup_label$' \
  /tmp/goodos-basebackup-list.txt

grep -Eq \
  '(^|/)backup_manifest$' \
  /tmp/goodos-basebackup-list.txt

grep -Eq \
  '(^|/)global/pg_control$' \
  /tmp/goodos-basebackup-list.txt

tar \
  -xzf "$TEMP_PLAINTEXT" \
  -C "$VERIFY_DIRECTORY"

"$PG_VERIFYBACKUP" \
  "$VERIFY_DIRECTORY"

ENTRY_COUNT="$(
  grep -cvE \
    '^(;|$)' \
    /tmp/goodos-basebackup-list.txt
)"

rm -f \
  "$TEMP_PLAINTEXT" \
  /tmp/goodos-basebackup-list.txt

rm -rf "$VERIFY_DIRECTORY"

chmod 600 "$TEMP_ENCRYPTED"

mv \
  "$TEMP_ENCRYPTED" \
  "$FILE_PATH"

CHECKSUM="$(
  sha256sum "$FILE_PATH" |
  awk '{print $1}'
)"

printf '%s  %s\n' \
  "$CHECKSUM" \
  "$FILE_NAME" \
  >"$TEMP_CHECKSUM"

chmod 600 "$TEMP_CHECKSUM"
mv "$TEMP_CHECKSUM" "$CHECKSUM_PATH"

SIZE_BYTES="$(
  stat -c '%s' "$FILE_PATH"
)"

COMPLETED_AT="$(date -u -Is)"
END_EPOCH="$(date +%s)"

DURATION_SECONDS="$(
  awk \
    -v start="$START_EPOCH" \
    -v finish="$END_EPOCH" \
    'BEGIN {
      printf "%.2f", finish - start
    }'
)"

KEY_FINGERPRINT="$(
  sha256sum "$RECIPIENT_FILE" |
  awk '{print $1}'
)"

VERIFY_ID="verify_base_age_${STAMP}_$RANDOM"

sudo -u postgres psql \
  -d "$DATABASE" \
  -v ON_ERROR_STOP=1 \
  -v backup_id="$BACKUP_ID" \
  -v file_path="$FILE_PATH" \
  -v file_name="$FILE_NAME" \
  -v size_bytes="$SIZE_BYTES" \
  -v checksum="$CHECKSUM" \
  -v started_at="$STARTED_AT" \
  -v completed_at="$COMPLETED_AT" \
  -v retention_until="$RETENTION_UNTIL" \
  -v key_fingerprint="$KEY_FINGERPRINT" \
  -v verify_id="$VERIFY_ID" \
  -v entry_count="$ENTRY_COUNT" \
  -v duration_seconds="$DURATION_SECONDS" <<'SQL'
BEGIN;

INSERT INTO backend_backup_inventory (
    id,
    backup_type,
    storage_type,
    file_path,
    file_name,
    size_bytes,
    checksum_sha256,
    database_name,
    started_at,
    completed_at,
    status,
    retention_until,
    metadata_json,
    created_at,
    updated_at
)
VALUES (
    :'backup_id',
    'postgres_base_pitr',
    'local_age_encrypted',
    :'file_path',
    :'file_name',
    :'size_bytes'::bigint,
    :'checksum',
    'postgres-cluster',
    :'started_at'::timestamptz,
    :'completed_at'::timestamptz,
    'completed',
    :'retention_until'::timestamptz,
    jsonb_build_object(
      'encryption',
      'age-x25519',
      'keyFingerprint',
      :'key_fingerprint',
      'format',
      'pg-basebackup-tar-gzip',
      'walMethod',
      'fetch',
      'manifestChecksums',
      'SHA256',
      'pgVerifyBackupPassed',
      true,
      'archiveEntryCount',
      :'entry_count'::int,
      'durationSeconds',
      :'duration_seconds'::numeric,
      'plaintextStored',
      false,
      'pitrCapable',
      true
    ),
    NOW(),
    NOW()
);

INSERT INTO backend_restore_verifications (
    id,
    backup_inventory_id,
    verification_type,
    target_environment,
    status,
    rpo_minutes,
    rto_minutes,
    started_at,
    completed_at,
    notes,
    evidence_json,
    created_at
)
VALUES (
    :'verify_id',
    :'backup_id',
    'encrypted_pitr_basebackup_integrity',
    'verification-only',
    'passed',
    0,
    NULL,
    :'started_at'::timestamptz,
    :'completed_at'::timestamptz,
    'Encrypted base backup passed checksum, archive and pg_verifybackup validation.',
    jsonb_build_object(
      'archiveEntryCount',
      :'entry_count'::int,
      'encrypted',
      true,
      'checksumRecorded',
      true,
      'backupLabelPresent',
      true,
      'backupManifestPresent',
      true,
      'pgControlPresent',
      true,
      'pgVerifyBackupPassed',
      true,
      'pitrCapable',
      true
    ),
    NOW()
);

COMMIT;
SQL

trap - EXIT

rm -f \
  "$PG_BASEBACKUP_ERROR" \
  "$AGE_ERROR"

echo "Encrypted PITR base backup completed:"
echo "  ID: $BACKUP_ID"
echo "  File: $FILE_PATH"
echo "  Size: $SIZE_BYTES"
echo "  SHA-256: $CHECKSUM"
echo "  Archive entries: $ENTRY_COUNT"
echo "  Duration: $DURATION_SECONDS seconds"
